# --- Server ---
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string

# --- Banking engine ---
# "simulated" = Option A, fake money, no external calls, works immediately
# "unit_sandbox" = Option B, real calls to Unit.co's free sandbox (test-mode, not real money)
BANKING_MODE=simulated

# --- Only required if BANKING_MODE=unit_sandbox ---
# Get these free at https://unit.co -> sign up -> Dashboard -> API Tokens (Sandbox)
UNIT_API_TOKEN=
UNIT_API_BASE_URL=https://api.s.unit.sh
